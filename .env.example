# ==============================================================
# ThreatSync AI Investigator — Environment Configuration
# Copy this file to .env and fill in your values
# ==============================================================

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://threatsync:threatsync@localhost:5432/threatsync

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Application ───────────────────────────────────────────────
APP_NAME=ThreatSync AI Investigator
DEBUG=false
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-256-bit-secret-key

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ── API Security (optional, recommended for production) ──────
# When enabled, clients must provide:
#   - X-API-Key for alerts/investigations and WebSocket (query param api_key)
#   - X-Analyst-Key for approvals and audit API
API_AUTH_ENABLED=false
API_KEY_SERVICE=service-dev-key
API_KEY_ANALYST=analyst-dev-key

# ── Investigation ─────────────────────────────────────────────
# Alerts with severity_score >= this value require human approval
APPROVAL_THRESHOLD=7.0
# Number of documents to retrieve per RAG query
RAG_TOP_K=5
